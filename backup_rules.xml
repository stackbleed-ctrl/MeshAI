<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for MeshAI.
    We exclude the encrypted database and keys — these should NOT be backed up
    as they contain sensitive mesh keys and agent memory.
-->
<full-backup-content>
    <!-- Exclude Room database (contains encrypted mesh keys) -->
    <exclude domain="database" path="meshai.db" />
    <exclude domain="database" path="meshai.db-shm" />
    <exclude domain="database" path="meshai.db-wal" />
    <!-- Exclude DataStore preferences (contains node identity + agent mode state) -->
    <exclude domain="file" path="datastore" />
    <!-- Exclude captured photos -->
    <exclude domain="file" path="captures" />
</full-backup-content>
